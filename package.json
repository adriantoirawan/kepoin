{
  "name": "kepoin",
  "version": "0.2.13",
  "description": "Zero-config forensic telemetry for Node.js and Node-based Mobile apps (React Native/Expo). Automatically trace execution, benchmark performance, and generate memory autopsies on crash, without changing a line of your code.",
  "type": "module",
  "types": "./src/index.d.ts",
  "main": "./src/index.js",
  "bin": {
    "kepoin": "bin/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src",
    "bin",
    "examples"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.cjs"
    },
    "./register": "./src/loaders/register.js",
    "./mobile": "./src/clients/mobile.js"
  },
  "keywords": [
    "telemetry",
    "observability",
    "debugging",
    "tracing",
    "forensics",
    "instrumentation",
    "proxy",
    "crash-reporting",
    "zero-config",
    "diagnostic",
    "developer-experience",
    "dx",
    "pii-redaction",
    "sanitization",
    "performance-monitoring",
    "memory-dump"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adriantoirawan/kepoin.git"
  },
  "license": "MIT",
  "author": "Adrianto Puji Irawan",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "homepage": "https://github.com/adriantoirawan/kepoin#readme",
  "bugs": {
    "url": "https://github.com/adriantoirawan/kepoin/issues"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
